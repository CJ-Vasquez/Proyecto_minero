sistema-logistico_V3/sistema-logistico/.nx/
sistema-logistico_V3/sistema-logistico/coverage/

# Cualquier node_modules en el repo
**/node_modules/
**/dist/
**/.angular/

# npm / yarn / pnpm
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.npm
.yarn
.pnp.*

# ============================================
# Variables de entorno locales
# ============================================
.env
.env.local
.env.*.local
application-local.properties

# ============================================
# Temporales
# ============================================
*.tmp
*.bak
*.swp
*~

# Archivos personales fuera del entregable
_archivos_personales/
.tmp_*
ENTREGA_FINAL/
