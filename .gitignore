*.zip
*.7z
*.tar
*.tar.gz

# ===== Sistema operativo =====
Thumbs.db
ehthumbs.db
Desktop.ini
.DS_Store

# ===== IDEs =====
.idea/
*.iml
*.ipr
*.iws
.project
.classpath
.settings/
.factorypath
nbproject/
.vscode/launch.json
.vscode/settings.json

# ============================================
# BACKEND - Spring Boot / Maven
# ============================================
sistema-logistico-minero/sistema-logistico-minero/target/
sistema-logistico-minero/sistema-logistico-minero/.mvn/wrapper/maven-wrapper.jar
sistema-logistico-minero/sistema-logistico-minero/HELP.md

# Java compilados y reportes
*.class
*.jar
*.war
*.ear
*.nar
hs_err_pid*
replay_pid*

# Logs
*.log
logs/

# ============================================
# FRONTEND - Angular / Node
# ============================================
sistema-logistico_V3/sistema-logistico/node_modules/
sistema-logistico_V3/sistema-logistico/.angular/
sistema-logistico_V3/sistema-logistico/dist/
sistema-logistico_V3/sistema-logistico/tmp/
